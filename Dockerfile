# ========== 1. Базовый образ с Python ==========
# Используем официальный образ Python 3.12 (легкий и быстрый)
FROM python:3.12-slim

# ========== 2. Устанавливаем рабочую директорию ==========
# Все дальнейшие команды будут выполняться внутри /app
WORKDIR /app

# ========== 3. Копируем зависимости ==========
# Сначала копируем только requirements.txt (для кэширования)
COPY requirements.txt .

# ========== 4. Устанавливаем зависимости ==========
# --no-cache-dir - не сохранять кэш pip (уменьшает размер образа)
RUN pip install --no-cache-dir -r requirements.txt

# ========== 5. Копируем весь проект ==========
# Копируем все файлы из текущей папки в /app
COPY . .

# ========== 6. Создаем папку для базы данных ==========
# SQLite будет создавать файл sales.db в этой папке
# RUN mkdir -p /app/data

# ========== 7. Открываем порт ==========
# Порт, на котором будет работать приложение
EXPOSE 8008

# ========== 8. Запускаем приложение ==========
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8008"]
